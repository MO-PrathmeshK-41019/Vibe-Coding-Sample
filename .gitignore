# Ignore Node modules if any
node_modules/

# Ignore environment files
.env
.env.local
.env.*.local
config.local.js

# Ignore OS files
.DS_Store
Thumbs.db
desktop.ini

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore build files (if you add a build process)
dist/
build/

# Ignore sensitive files
*.key
*.pem
*.cert
credentials.json
secrets.json

# Ignore backup files
*.bak
*.backup
*~

# Ignore temporary files
.tmp/
temp/
*.tmp
