# ========================================
# SQL Server Connection Configuration
# ========================================

# Database credentials
DB_USER=app_admin
DB_PASSWORD=app_admin_123
DB_SERVER=10.28.56.122,24115
# For Azure SQL: yourserver.database.windows.net
# For local: localhost or 127.0.0.1

DB_PORT=1433
DB_DATABASE=msdb

# Connection options
DB_ENCRYPT=false
# Set to 'true' for Azure SQL Database
# Set to 'false' for local SQL Server

DB_TRUST_CERT=true
# Set to 'true' for local development (self-signed certs)
# Set to 'false' for production with valid SSL certificates

# ========================================
# API Server Configuration
# ========================================

PORT=3000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080
# For production, set to your GitHub Pages URL:
# FRONTEND_URL=https://yourusername.github.io

# ========================================
# Optional: API Security
# ========================================

# Uncomment and set if you want API key authentication
# API_KEY=your-secret-api-key-here

# ========================================
# Example Configurations
# ========================================

# LOCAL SQL SERVER (Windows Authentication)
# DB_USER=sa
# DB_PASSWORD=YourStrongPassword123
# DB_SERVER=localhost
# DB_ENCRYPT=false
# DB_TRUST_CERT=true

# AZURE SQL DATABASE
# DB_USER=sqladmin
# DB_PASSWORD=YourStrongPassword123!
# DB_SERVER=yourserver.database.windows.net
# DB_ENCRYPT=true
# DB_TRUST_CERT=false

# REMOTE SQL SERVER
# DB_USER=sql_user
# DB_PASSWORD=YourPassword123
# DB_SERVER=192.168.1.100
# DB_PORT=1433
# DB_ENCRYPT=false
# DB_TRUST_CERT=true
